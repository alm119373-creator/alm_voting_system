# Example environment variables for local development or deployment
# Copy this file to .env and fill in real values (do NOT commit .env)

# PostgreSQL connection (Railway or local)
DATABASE_URL=postgresql://<RAILWAY_DB_USER>:<RAILWAY_DB_PASSWORD>@<RAILWAY_HOST>:<RAILWAY_PORT>/<RAILWAY_DB_NAME>

# Secret key for token signing (change for production)
SECRET_KEY=your_secret_key_here

# Optional: API base URL for frontend
# NEXT_PUBLIC_API_URL=http://localhost:8000
